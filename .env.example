# Получить у @BotFather в Telegram (команда /newbot)
TELEGRAM_BOT_TOKEN=

# Опционально: ключ Anthropic API для человеко-понятных объяснений в antifraud-модуле.
# Без ключа rule-based скоринг работает полностью автономно, просто без LLM-объяснений.
ANTHROPIC_API_KEY=

# Путь к файлу базы данных для локальной разработки (можно не менять)
DB_PATH=aqylmoney.db

# Опционально: облачная база Turso (libSQL), нужна только на проде (Render), чтобы данные
# переживали передеплои — на бесплатном тарифе Render диск эфемерный и стирается при каждом
# деплое. Без этих двух переменных бот всегда использует локальный файл из DB_PATH.
# Как завести: turso.tech → создать базу → скопировать "Database URL" и создать auth token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Опционально: превратить бота в Telegram Mini App (веб-интерфейс внутри Telegram).
# Публичный HTTPS-адрес, на котором будет доступен веб-сервер (см. README, раздел про ngrok).
# Без этой переменной бот работает в обычном режиме — инлайн-кнопки, без веб-интерфейса.
WEBAPP_URL=

# Порт локального веб-сервера (то, что должен проксировать ngrok/localtunnel)
WEBAPP_PORT=8080
